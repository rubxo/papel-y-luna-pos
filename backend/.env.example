# ============================================================
# PAPEL & LUNA POS — Variables de entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# Entorno: development | production | test
NODE_ENV=production

# Puerto del servidor
PORT=8000

# JWT — CAMBIA ESTO en produccion (minimo 32 caracteres)
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_AL_MENOS_32_CHARS
JWT_EXPIRES_IN=8h

# IVA y configuracion de negocio
IVA_RATE=0.19
LOW_STOCK_THRESHOLD=10

# Base de datos MySQL (produccion)
# En Railway se proveen automaticamente como variables de entorno
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=papel_luna_pos
DB_USER=root
DB_PASSWORD=

# CORS — URL del frontend desplegado
# Puede ser una URL o varias separadas por coma
# Ejemplos:
#   Netlify: https://papel-luna.netlify.app
#   Railway: https://papel-luna-backend.up.railway.app
#   Multiples: https://papel-luna.netlify.app,https://papel-luna.vercel.app
FRONTEND_URL=https://TU-FRONTEND.netlify.app
