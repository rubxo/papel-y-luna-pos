# ============================================================
# PAPEL & LUNA POS — Variables de entorno
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Completa los valores marcados con <REEMPLAZAR>
# 3. NUNCA subas el .env real a Git (.gitignore ya lo excluye)
# ============================================================

# ── ENTORNO ──────────────────────────────────────────────────
# development | production | test
NODE_ENV=production

# Puerto del servidor (Render lo asigna automáticamente con $PORT)
PORT=8000

# ── JWT ──────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios.
# Generar: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
JWT_SECRET=<REEMPLAZAR_CON_CLAVE_SEGURA_DE_AL_MENOS_32_CHARS>
JWT_EXPIRES_IN=8h

# ── BASE DE DATOS ─────────────────────────────────────────────
# En Render (MySQL): las variables DB_* se configuran en el panel
# de Environment de tu Web Service, tomándolas del servicio MySQL.
# En desarrollo local con SQLite: dejar en blanco o comentar.
DB_HOST=<HOST_MYSQL_RENDER>
DB_PORT=3306
DB_NAME=papel_luna_pos
DB_USER=<USUARIO_MYSQL>
DB_PASSWORD=<PASSWORD_MYSQL>

# ── CORS ──────────────────────────────────────────────────────
# URL del frontend. Puede ser una o varias separadas por coma.
# Ejemplos:
#   Netlify:   https://papelyluna.netlify.app
#   Vercel:    https://papelyluna.vercel.app
#   Multiples: https://papelyluna.netlify.app,https://papelyluna.vercel.app
#   Localhost: * (solo desarrollo — NO usar en producción)
FRONTEND_URL=https://papelyluna.netlify.app

# ── NEGOCIO ───────────────────────────────────────────────────
# IVA de Colombia: 19% = 0.19
IVA_RATE=0.19
# Umbral de alerta de stock bajo (unidades)
LOW_STOCK_THRESHOLD=10

# ── GUÍA DE DESPLIEGUE EN RENDER ─────────────────────────────
# 1. Crea un Web Service apuntando a este repositorio
#    - Root Directory: backend
#    - Build Command:  npm install && npm run db:migrate && npm run db:seed
#    - Start Command:  npm start
# 2. Agrega un servicio MySQL en Render y copia las credenciales aquí
# 3. Configura las variables de entorno en el panel de Render
#    (NO uses este archivo directamente en producción)
# 4. En FRONTEND_URL pon la URL de tu sitio en Netlify/Vercel
